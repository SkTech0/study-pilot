# =============================================================================
# StudyPilot – Central AI configuration (API keys + AI service URL)
# =============================================================================
# Copy this file and fill in values. Use as reference; each component reads
# from its own location (see below).
#
# 503 "AI service is temporarily unavailable" → .NET API cannot reach the
# Python AI service. Fix: (1) Start Python AI on port 8000. (2) Ensure
# AIService:BaseUrl matches (see .NET section).
# =============================================================================

# -----------------------------------------------------------------------------
# .NET API (calls Python AI service)
# Set via appsettings.Development.json or environment variables.
# For local run: BaseUrl must be http://localhost:8000 when Python runs on host.
# -----------------------------------------------------------------------------
# AIService__BaseUrl=http://localhost:8000
# AIService__TimeoutSeconds=300

# -----------------------------------------------------------------------------
# Python AI service (LLM + embeddings)
# Copy the keys below into study-pilot-ai/.env (or set in environment).
# At least one key is required for chat, tutor, quiz generation (non-mock).
# -----------------------------------------------------------------------------
# Fallback chain: first available provider is primary; 429/failure tries next.
# LLM_FALLBACK_CHAIN=gemini,deepseek,openrouter,openai

# 1) Gemini (recommended). https://aistudio.google.com/apikey
# GEMINI_API_KEY=

# 2) DeepSeek. https://platform.deepseek.com
# DEEPSEEK_API_KEY=

# 3) OpenRouter (one key, many models). https://openrouter.ai
# OPENROUTER_API_KEY=

# 4) OpenAI. https://platform.openai.com
# OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Where each app reads config
# -----------------------------------------------------------------------------
# .NET API:  src/StudyPilot.API/appsettings.json + appsettings.Development.json
#            Env override: AIService__BaseUrl, AIService__TimeoutSeconds
# Python:    study-pilot-ai/.env (copy from study-pilot-ai/.env.example)
# Docker:    deploy/.env (see deploy/.env.example)
