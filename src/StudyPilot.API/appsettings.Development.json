{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Microsoft.Hosting": "Warning",
      "StudyPilot.Infrastructure.BackgroundJobs": "Information",
      "StudyPilot.Infrastructure.Storage": "Information",
      "StudyPilot.Infrastructure.Knowledge": "Information",
      "StudyPilot.API.Middleware.RequestLoggingMiddleware": "Information"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.Hosting": "Warning",
        "StudyPilot.Infrastructure.BackgroundJobs": "Information",
        "StudyPilot.Infrastructure.Storage": "Information",
        "StudyPilot.Infrastructure.Knowledge": "Information",
        "StudyPilot.API.Middleware.RequestLoggingMiddleware": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": { "restrictedToMinimumLevel": "Warning" }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/study-pilot-dev-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ]
  },
  "ConnectionStrings": {
    "Default": "Host=localhost;Database=StudyPilot;Username=studypilot;Password=postgres",
    "DefaultConnection": "Host=localhost;Database=StudyPilot;Username=studypilot;Password=postgres"
  },
  "Jwt": {
    "Secret": "dev-secret-min-32-chars-for-hmac-sha256",
    "Key": "dev-secret-min-32-chars-for-hmac-sha256",
    "Issuer": "StudyPilot",
    "Audience": "StudyPilot",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 7
  },
  "AIService": {
    "BaseUrl": "http://localhost:8000",
    "TimeoutSeconds": 300,
    "LlmTimeoutSeconds": 180,
    "QuestionGenerationRetryBaseDelayMs": 200
  },
  "UsageGuard": {
    "MaxQuizGenerationPerHour": 60,
    "MaxDocumentsPerUserPerDay": 50
  },
  "BackgroundJobs": {
    "ProcessingTimeoutMinutes": 30
  }
}
