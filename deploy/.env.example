ConnectionStrings__Default=Host=postgres;Database=StudyPilot;Username=studypilot;Password=CHANGE_ME
Jwt__Secret=CHANGE_ME_MIN_32_CHARS
Jwt__Issuer=StudyPilot
Jwt__Audience=StudyPilot
Jwt__AccessTokenMinutes=15
Jwt__RefreshTokenDays=7
POSTGRES_USER=studypilot
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=StudyPilot
# Multi-LLM: gemini → deepseek → openrouter (only providers with keys are used)
LLM_FALLBACK_CHAIN=gemini,deepseek,openrouter
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
# Legacy fallback when no chain keys set
OPENAI_API_KEY=
LLM_PROVIDER=gemini

AIService__TimeoutSeconds=60
AIService__MaxTextLength=50000
