# Multi-LLM fallback chain (first = primary). Only providers with keys set are used.
# If only one key is set (e.g. GEMINI_API_KEY), that provider is used alone.
# Set multiple keys to get fallback: on 429/failure the next provider in the chain is tried.
LLM_FALLBACK_CHAIN=gemini,deepseek,openrouter

# 1️⃣ Gemini (primary). Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# 2️⃣ DeepSeek (fallback). https://platform.deepseek.com
DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat

# 3️⃣ OpenRouter (fallback). One key, many models: https://openrouter.ai
OPENROUTER_API_KEY=
# OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free

# Legacy single-provider (used only if no keys in LLM_FALLBACK_CHAIN)
# OPENAI_API_KEY=
# LLM_PROVIDER=gemini
