# StudyPilot AI – LLM keys. See also config/ai.env.example (central list for .NET + Python).
# AI mode: "real" (default) or "mock" — mock returns fake responses for local testing without API keys.
# For real chat/tutor/quiz set at least one key below and use AI_MODE=real (or omit).
# AI_MODE=mock

# Multi-LLM fallback chain (first = primary). Only providers with keys set are used (ollama needs no key).
# On 429 rate limit or failure we fail over to the next provider quickly so users don't notice.
# Ollama (local) first, then cloud: e.g. ollama,gemini,deepseek,openrouter,openai
LLM_FALLBACK_CHAIN=ollama,gemini,deepseek,openrouter,openai

# 0️⃣ Ollama (local, no key). Run: ollama pull llama3:8b. For faster UI use a smaller model: ollama pull llama3.2:3b
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3:8b
# OLLAMA_STREAM=true

# 1️⃣ Gemini. Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# 2️⃣ DeepSeek (fallback). https://platform.deepseek.com
DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat

# 3️⃣ OpenRouter (fallback). One key, many models: https://openrouter.ai
OPENROUTER_API_KEY=
# Default model: google/gemini-2.5-flash. Free tier: OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free
# OPENROUTER_MODEL=google/gemini-2.5-flash

# 4️⃣ OpenAI (fallback). https://platform.openai.com
# OPENAI_API_KEY=

# Legacy single-provider (used only if no keys in LLM_FALLBACK_CHAIN)
# LLM_PROVIDER=gemini
